{
  "name": "marius-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "docker:build": "docker build -t tasklist-frontend:latest .",
    "docker:run": "docker run -d -p 80:80 --name tasklist-frontend tasklist-frontend:latest",
    "docker:compose": "docker compose up --build",
    "security:scan-trivy": "trivy image --severity CRITICAL,HIGH --format table tasklist-frontend:latest",
    "security:sbom-spdx": "trivy image --format spdx-json --output sbom-spdx.json tasklist-frontend:latest",
    "security:sbom-cyclonedx": "trivy image --format cyclonedx --output sbom-cyclonedx.json tasklist-frontend:latest"
  },
  "dependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "sonarqube-scanner": "^4.3.8",
    "typescript": "~6.0.2",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
